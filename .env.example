# Example environment variables for Cosmos DB integration

# Required: Cosmos DB connection string (primary key)
COSMOS_CONNECTION_STRING="AccountEndpoint=https://<your-account>.documents.azure.com:443/;AccountKey=<your-key>;"

# Optional: database and container names (default: Isotopes)
COSMOS_DATABASE="Isotopes"
COSMOS_CONTAINER="Isotopes"

# # Enable remote persistence; set to "true" to use Cosmos DB via the /isotopes endpoint.
VITE_USE_COSMOS=true
